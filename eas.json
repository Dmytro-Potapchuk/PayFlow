{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "ios-preview": {
      "extends": "production",
      "distribution": "store",
      "channel": "ios-preview",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "ios-preview": {},
    "production": {}
  }
}
